# Copy this file to .env and fill in your values.

# OpenAI API key (required for LLM features)
OPENAI_API_KEY=sk-...

# Set to "true" to enable LLM calls; "false" for offline/test mode
LLM_ENABLED=true

# Default model for all agents (overridden per-agent below)
LLM_MODEL=gpt-4o-mini

# Per-agent model overrides: LLM_MODEL_<AGENT_NAME_UPPERCASE>
LLM_MODEL_COMMUNICATION=gpt-5.4-mini

# Rate and cost guardrails
LLM_MAX_CALLS_PER_MINUTE=30
LLM_MAX_COST_PER_DAY=5.00
LLM_TIMEOUT_SECONDS=15

# Telegram bot token
TELEGRAM_BOT_TOKEN=...

# Database URL
DATABASE_URL=postgresql://user:password@localhost:5432/constituency_os
